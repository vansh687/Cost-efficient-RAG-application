# Server Config
PORT=8000
HOST=0.0.0.0

# LLM Providers Configuration (Default to gemini or openai)
# Choose one of: gemini, openai, mockup
LLM_PROVIDER=gemini
EMBEDDING_PROVIDER=gemini

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# RAG Settings
VECTOR_DB_PATH=./chroma_db
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K=5
similarity_threshold=0.3
